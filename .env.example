# BidReady 24 — Environment Variables (NO SECRETS IN REPO)
# Copy to .env.local for local dev. Never commit real keys.

# App
NODE_ENV=production
APP_URL=https://bidready24.com
ADMIN_PASSWORD=change-me-in-prod   # IMPORTANT: Set a strong value in Render Dashboard secrets only

# Database (sqlite for MVP)
DATABASE_PATH=./data/bidready.db

# Storage (local for MVP)
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=200
MAX_FILES_PER_PROJECT=20

# Stripe (use TEST keys only until owner approval for live)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Magic links / tokens
MAGIC_LINK_EXPIRY_DAYS=7

# Email (stub for MVP - logs to console; replace with Resend etc after approval)
# RESEND_API_KEY=re_...
# EMAIL_FROM=hello@yourdomain.com

# AI (stub only for concierge MVP. Provide real key + approve before use)
# AI_PROVIDER=anthropic|openai
# ANTHROPIC_API_KEY=...
# OPENAI_API_KEY=...

# Retention
DEFAULT_RETENTION_DAYS=30

# Feature flags (MVP)
ENABLE_REAL_AI=false
ENABLE_RECURRING=false

# Render deployment notes (for bidready24.com)
# - Use Render Blueprint (render.yaml in repo)
# - Attach Disk at /data for DATABASE_PATH and UPLOAD_DIR
# - Set all *_KEY and ADMIN_PASSWORD via Render Environment > Secrets (never in code)
# - After first deploy, add custom domain bidready24.com in the Render service settings
# - Run db:migrate on first deploy via startCommand or Render Shell
# - For real Stripe: switch from simulated checkout in app/api/checkout/route.ts and add webhook

