# BidReady 24 — Environment Variables (NO SECRETS IN REPO)
# Copy to .env.local for local dev. Never commit real keys.

# App
NODE_ENV=production
APP_URL=https://www.bidready24.com
ADMIN_PASSWORD=change-me-in-prod   # IMPORTANT: Set a strong value in Render Dashboard secrets only
ADMIN_SESSION_SECRET=replace-with-random-secret
CUSTOMER_SESSION_SECRET=replace-with-random-secret
PROJECT_TOKEN_TTL_HOURS=168

# Database (sqlite for MVP)
DATABASE_PATH=./data/bidready.db

# Storage (local for MVP)
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=200
MAX_FILES_PER_PROJECT=20

# Stripe hosted Checkout (use live keys only in the production secret store)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
CHECKOUT_SESSION_SECRET=replace-with-random-secret
# Local development only. This flag is ignored in production.
ALLOW_SIMULATED_CHECKOUT=false

# Magic links / tokens
MAGIC_LINK_EXPIRY_DAYS=7
# Project return access uses intake contact_email + project id (see /login and /api/access).
# Optional: SUPPORT_WEBHOOK_URL receives project_access_link events for email delivery.

# Email / alerts delivery (stub logs to console when unset)
# RESEND_API_KEY=re_...
# EMAIL_FROM=hello@yourdomain.com
# ALERT_WEBHOOK_URL=https://adapter.example/alerts
# ALERT_WEBHOOK_SECRET=...
# ALERTS_CRON_SECRET=replace-with-random-secret   # Bearer token for POST /api/alerts/check-tenders


# Autonomous analysis (deterministic extraction remains available when no key is set)
ENABLE_REAL_AI=true
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.6

# Optional customer-authorised external action adapters
# OUTBOUND_ACTION_WEBHOOK_URL=https://adapter.example/clarifications
# OUTBOUND_ACTION_WEBHOOK_SECRET=...
# SUBMISSION_WEBHOOK_URL=https://adapter.example/submissions
# SUBMISSION_WEBHOOK_SECRET=...
# SUPPORT_WEBHOOK_URL=https://adapter.example/support
# SUPPORT_WEBHOOK_SECRET=...
# SUPPORT_RATE_LIMIT_SALT=replace-with-random-secret

# Retention
DEFAULT_RETENTION_DAYS=30

# Feature flags (MVP)
ENABLE_RECURRING=false

# Render deployment notes (for bidready24.com)
# - Use Render Blueprint (render.yaml in repo)
# - Attach Disk at /data for DATABASE_PATH and UPLOAD_DIR
# - Set all *_KEY and ADMIN_PASSWORD via Render Environment > Secrets (never in code)
# - After first deploy, add www.bidready24.com and bidready24.com in Render; keep www canonical
# - Run db:migrate on first deploy via startCommand or Render Shell
# - Configure the Stripe webhook endpoint as https://www.bidready24.com/api/webhooks/stripe
